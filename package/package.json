{
  "name": "@pantheon-systems/nextjs-cache-handler",
  "version": "0.1.0",
  "description": "Custom cache handler for Next.js with support for Google Cloud Storage and file-based caching",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "next.js",
    "cache",
    "cache-handler",
    "gcs",
    "google-cloud-storage",
    "pantheon"
  ],
  "author": "Pantheon Systems",
  "license": "MIT",
  "peerDependencies": {
    "next": ">=14.0.0"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pantheon-systems/nextjs-cache-handler"
  }
}
